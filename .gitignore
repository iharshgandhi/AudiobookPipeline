# ---------------------------------------------------------------------------
#  Config — keep secrets out of git
# ---------------------------------------------------------------------------
config.local.json

# ---------------------------------------------------------------------------
#  Generated folders — never commit these
# ---------------------------------------------------------------------------
Prompts/
Images/
HindiClean/
AudioSingle/
AudioMulti/
Videos/

# ---------------------------------------------------------------------------
#  User input folders — content is per-book, don't track
# ---------------------------------------------------------------------------
EnglishSource/*
HaikuOutput/*
HindiTagged/*
# But keep the folders themselves (they're expected to exist)
!EnglishSource/.gitkeep
!HaikuOutput/.gitkeep
!HindiTagged/.gitkeep

# ---------------------------------------------------------------------------
#  Python
# ---------------------------------------------------------------------------
.venv/
__pycache__/
scripts/__pycache__/
*.pyc
*.pyo

# ---------------------------------------------------------------------------
#  macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
#  IDE
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
